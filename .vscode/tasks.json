{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Android: Run App",
      "type": "shell",
      "command": "${workspaceFolder}\\run-app.bat",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Build Debug APK",
      "type": "shell",
      "command": "${workspaceFolder}\\gradlew.bat",
      "args": [
        "assembleDebug",
        "--console=plain"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
